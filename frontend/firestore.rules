rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jomstudio.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── Productos (Catálogo) ──────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true; // catálogo público
      allow update: if isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['views', 'sales', 'stock', 'warehouseStock']);
      allow create, delete: if isAdmin();
    }

    // ── Usuarios y Clientes CRM ───────────────────────────────────────────
    match /users/{userId} {
      // El admin puede leer y escribir cualquier perfil
      allow read, write: if isAdmin();
      // El cliente solo puede leer y actualizar su propio perfil
      allow read, update: if isOwner(userId);
      // La creación requiere que el request lo haga el propio usuario autenticado
      allow create: if request.auth != null && request.auth.uid == userId;

      // Subcolección de notificaciones del usuario
      match /notifications/{notificationId} {
        allow read, update: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin() || request.auth != null; // Cualquiera autenticado puede crear (ej: al comprar), pero idealmente el admin o el sistema
      }
    }

    // ── Inventario ───────────────────────────────────────────────────────
    match /inventory/{productId} {
      allow read, write: if isAdmin();
    }

    // ── Órdenes ──────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid) || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ── Pagos y Facturas (Solo lectura frontend, escritura Admin/Cloud Function) ───
    match /invoices/{invoiceId} {
      allow read: if isOwner(resource.data.uid);
      allow write: if isAdmin();
    }
    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    // ── Logs Administrativos ──────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read, write, delete: if isAdmin();
      allow create: if request.auth != null; // sistema puede crear logs
    }

    // ── Tasas de cambio ──────────────────────────────────────────────────
    match /exchangeRates/{rateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Store Config (Flash Offers, etc) ──────────────────────────────────
    match /store/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
