rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es el Admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@jomstudio.com';
    }

    // Reglas para Productos (Catálogo)
    match /products/{productId} {
      allow read: if true; // Cualquiera puede ver el catálogo
      
      // Permitir a usuarios normales actualizar compras y vistas
      allow update: if isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'sales', 'stock', 'warehouseStock']);
      
      // Solo admin puede crear o borrar productos o editar precios
      allow create, delete: if isAdmin();
      allow write: if isAdmin();
    }

    // Reglas temporales para el resto (usuarios y órdenes) para no romper el flujo
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if true; // Fallback temporal para orders y adminLogs mientras se migra completo
    }
  }
}
